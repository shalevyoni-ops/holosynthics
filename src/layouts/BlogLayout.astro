---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} type="article">
  <slot name="head" slot="head">
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ScholarlyArticle",
        "headline": title,
        "description": description,
        "datePublished": pubDate.toISOString(),
        "author": {
          "@type": "Person",
          "name": "Yonathan Shalev",
          "affiliation": "Growing Intelligence"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Holosynthics"
        }
      })}
    </script>
  </slot>

  <Nav />

  <main class="blog-post">
    <div class="container">
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && <span class="updated">Updated {updatedDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>}
      </div>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <div class="divider"></div>
      <div class="content">
        <slot />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding: 120px 24px 80px;
    min-height: 100vh;
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
  }

  .meta {
    display: flex;
    gap: 16px;
    align-items: center;
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 24px;
  }

  .updated {
    background: rgba(0,217,255,0.1);
    color: var(--cyan);
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
  }

  h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    background: linear-gradient(135deg, #fff 0%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lead {
    font-size: 18px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 40px;
  }

  .content :global(h2) {
    font-size: 24px;
    font-weight: 700;
    margin: 40px 0 16px;
    color: var(--cyan);
  }

  .content :global(h3) {
    font-size: 18px;
    font-weight: 600;
    margin: 28px 0 12px;
  }

  .content :global(p) {
    margin-bottom: 20px;
    color: #CBD5E1;
    line-height: 1.8;
  }

  .content :global(strong) {
    color: #fff;
    font-weight: 600;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 14px;
    overflow-x: auto;
    display: block;
  }

  .content :global(th) {
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid rgba(0,217,255,0.3);
    color: var(--cyan);
    font-weight: 600;
    white-space: nowrap;
  }

  .content :global(td) {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    color: #CBD5E1;
  }

  .content :global(tr:hover td) {
    background: rgba(255,255,255,0.03);
  }

  .content :global(a) {
    color: var(--cyan);
    text-decoration: underline;
    text-decoration-color: rgba(0,217,255,0.4);
    text-underline-offset: 3px;
  }

  .content :global(code) {
    background: rgba(255,255,255,0.08);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    color: var(--cyan);
  }

  .content :global(ul), .content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
    color: #CBD5E1;
  }

  .content :global(li) {
    margin-bottom: 8px;
    line-height: 1.7;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--cyan);
    padding-left: 20px;
    margin: 24px 0;
    color: var(--muted);
    font-style: italic;
  }
</style>
