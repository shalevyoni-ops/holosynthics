---
export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  image = '/og.png',
  type = 'website',
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteName = 'Holosynthics';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI interpretability, periodic table AI, hallucination detection, neuron analysis, AI model safety, Holosynthics" />
    <meta name="author" content="Yonathan Shalev, Growing Intelligence" />
    <link rel="canonical" href={canonicalURL} />
    <title>{fullTitle}</title>

    <!-- OpenGraph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Holosynthics",
        "url": "https://holosynthics.com",
        "description": "AI model interpretability through neuron-level decomposition. We discovered the 56-element Periodic Table of AI.",
        "founder": {
          "@type": "Person",
          "name": "Yonathan Shalev"
        },
        "knowsAbout": ["AI interpretability", "neural network analysis", "hallucination detection", "model editing"]
      })}
    </script>

    <slot name="head" />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #080A18;
        --bg2: #0D0F23;
        --cyan: #00D9FF;
        --pink: #F72585;
        --purple: #7209B7;
        --blue: #4CC9F0;
        --green: #22C55E;
        --yellow: #FFD60A;
        --amber: #F59E0B;
        --red: #EF4444;
        --text: #E2E8F0;
        --muted: #8892A4;
        --border: rgba(255,255,255,0.08);
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: var(--cyan); text-decoration: none; }
      a:hover { text-decoration: underline; }

      img { max-width: 100%; display: block; }

      ::selection { background: rgba(0,217,255,0.25); }

      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: rgba(0,217,255,0.3); border-radius: 3px; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
