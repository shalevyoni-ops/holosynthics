---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ATOM_TYPES, ALL_ELEMENTS } from '../data/elements';

const TYPE_COLORS: Record<string, string> = Object.fromEntries(
  ATOM_TYPES.map(t => [t.symbol, t.color])
);
---

<BaseLayout
  title="Live Demo — Decompose & Recompose"
  description="Upload any file. Holosynthics decomposes it into digital atoms, maps each atom to one of 56 elements, then recomposes it perfectly. Round-trip verified."
>
  <Nav />

  <main class="demo-page">

    <!-- Hero -->
    <section class="demo-hero">
      <div class="hero-glow"></div>
      <div class="container">
        <div class="badge">Live Demo</div>
        <h1>Decompose Any File.<br /><span class="accent">See Every Atom.</span></h1>
        <p class="hero-sub">Upload an image, audio file, or PDF. Holosynthics decomposes it into digital atoms — each mapped to the 56-element periodic table — then recomposes it perfectly.</p>
      </div>
    </section>

    <!-- Upload Section -->
    <section class="section" id="upload-section">
      <div class="container">
        <div class="step-label">Step 1</div>
        <h2 class="step-title">Upload a File</h2>

        <div class="upload-zone" id="drop-zone">
          <div class="upload-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
          </div>
          <p class="upload-main">Drop your file here or <label class="upload-link" for="file-input">browse</label></p>
          <p class="upload-sub">Supports: images (PNG, JPG, WEBP) · audio (MP3, WAV) · documents (PDF)</p>
          <input type="file" id="file-input" accept="image/*,audio/*,.pdf" class="sr-only" />
        </div>

        <div class="file-preview" id="file-preview" style="display:none">
          <div class="preview-card">
            <div class="preview-icon" id="preview-icon">📄</div>
            <div class="preview-info">
              <span class="preview-name" id="preview-name">filename.pdf</span>
              <span class="preview-size" id="preview-size">2.4 MB</span>
            </div>
            <button class="preview-remove" id="remove-file" aria-label="Remove file">✕</button>
          </div>
          <img id="preview-img" class="preview-img" style="display:none" alt="Preview" />
          <audio id="preview-audio" class="preview-audio" controls style="display:none"></audio>
        </div>

        <div class="demo-controls">
          <button class="btn-primary" id="decompose-btn" disabled>
            <span id="decompose-label">Decompose</span>
            <span id="decompose-spinner" class="spinner" style="display:none"></span>
          </button>
          <span class="or-sep">or</span>
          <button class="btn-ghost" id="demo-btn">Try with demo data</button>
        </div>
      </div>
    </section>

    <!-- Results Section (hidden until decompose) -->
    <section class="section results-section" id="results-section" style="display:none">
      <div class="container">
        <div class="step-label">Step 2</div>
        <h2 class="step-title">Atoms Found</h2>

        <div class="results-count" id="results-count">
          <span class="count-num" id="atom-count">0</span>
          <span class="count-label">atoms found</span>
          <span class="count-sep">·</span>
          <span class="count-num" id="element-count">0</span>
          <span class="count-label">of 56 elements</span>
        </div>

        <!-- Mini Periodic Table -->
        <div class="mini-table-wrap">
          <h3 class="table-label">Elements Present</h3>
          <div class="mini-table" id="mini-table">
            {ATOM_TYPES.map(type => (
              <div class="mini-col" data-type={type.symbol}>
                <div class="mini-header" style={`color: ${type.color};`}>{type.symbol}</div>
                {type.elements.map(el => (
                  <div
                    class="mini-cell"
                    id={`mc-${el.id}`}
                    data-el={el.name}
                    data-type={type.symbol}
                    title={`${el.name} (${type.symbol})`}
                    style={`--ec: ${type.color};`}
                  >
                    {el.id}
                  </div>
                ))}
              </div>
            ))}
          </div>
          <div class="table-legend">
            {ATOM_TYPES.map(t => (
              <div class="legend-item">
                <span class="legend-dot" style={`background: ${t.color};`}></span>
                <span class="legend-name">{t.name}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Atom List -->
        <div class="atom-list-wrap">
          <h3 class="table-label">Atom Breakdown</h3>
          <div class="atom-list" id="atom-list"></div>
        </div>

        <!-- Recompose -->
        <div class="recompose-bar">
          <button class="btn-primary" id="recompose-btn">
            <span id="recompose-label">Recompose</span>
            <span id="recompose-spinner" class="spinner" style="display:none"></span>
          </button>
          <span class="recompose-hint">Reconstructs the original file from atoms</span>
        </div>
      </div>
    </section>

    <!-- Comparison Section (hidden until recompose) -->
    <section class="section compare-section" id="compare-section" style="display:none">
      <div class="container">
        <div class="step-label">Step 3</div>
        <h2 class="step-title">Round-Trip Verification</h2>

        <div class="verify-badge" id="verify-badge">
          <span class="badge-icon">✓</span>
          <span class="badge-text">Round-trip verified: <strong>100% identical</strong></span>
        </div>

        <div class="compare-grid">
          <div class="compare-card">
            <div class="compare-label">Original</div>
            <div class="compare-content" id="original-content"></div>
          </div>
          <div class="compare-arrow">→</div>
          <div class="compare-card">
            <div class="compare-label">Reconstructed</div>
            <div class="compare-content" id="reconstructed-content"></div>
          </div>
        </div>

        <div class="restart-bar">
          <button class="btn-ghost" id="restart-btn">← Try another file</button>
          <a href="/probe56" class="btn-primary">Run full Probe56 scan →</a>
        </div>
      </div>
    </section>

    <!-- Error banner (hidden) -->
    <div class="error-banner" id="error-banner" style="display:none">
      <span id="error-text">An error occurred. Please try again.</span>
      <button class="error-close" id="error-close">✕</button>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Layout ── */
  .demo-page { padding-top: 64px; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

  /* ── Hero ── */
  .demo-hero {
    position: relative;
    padding: 80px 24px 60px;
    text-align: center;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -120px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(0,217,255,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .badge {
    display: inline-block;
    background: rgba(0,217,255,0.1);
    color: var(--cyan);
    border: 1px solid rgba(0,217,255,0.3);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .demo-hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 16px;
    color: #fff;
  }
  .accent { color: var(--cyan); }
  .hero-sub {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Sections ── */
  .section { padding: 60px 0; border-top: 1px solid var(--border); }
  .step-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 8px;
  }
  .step-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 28px;
  }

  /* ── Upload zone ── */
  .upload-zone {
    border: 2px dashed rgba(0,217,255,0.3);
    border-radius: 16px;
    padding: 56px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    background: rgba(0,217,255,0.03);
  }
  .upload-zone.drag-over {
    border-color: var(--cyan);
    background: rgba(0,217,255,0.07);
  }
  .upload-icon { color: var(--cyan); margin-bottom: 16px; opacity: 0.7; }
  .upload-main { font-size: 1rem; color: var(--text); margin-bottom: 8px; }
  .upload-link { color: var(--cyan); cursor: pointer; text-decoration: underline; }
  .upload-sub { font-size: 13px; color: var(--muted); }

  /* ── File preview ── */
  .file-preview { margin-top: 20px; }
  .preview-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
  }
  .preview-icon { font-size: 24px; }
  .preview-info { flex: 1; min-width: 0; }
  .preview-name { display: block; font-weight: 600; font-size: 14px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .preview-size { font-size: 12px; color: var(--muted); }
  .preview-remove { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 16px; padding: 4px 8px; border-radius: 6px; transition: color 0.2s, background 0.2s; }
  .preview-remove:hover { color: #fff; background: rgba(255,255,255,0.08); }
  .preview-img { width: 100%; max-height: 240px; object-fit: contain; border-radius: 10px; margin-top: 12px; background: rgba(255,255,255,0.04); }
  .preview-audio { width: 100%; margin-top: 12px; }

  /* ── Buttons ── */
  .demo-controls {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--cyan), #0099BB);
    color: #080A18;
    font-weight: 700;
    font-size: 15px;
    padding: 12px 28px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    text-decoration: none;
  }
  .btn-primary:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); text-decoration: none; color: #080A18; }
  .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--cyan);
    font-weight: 600;
    font-size: 14px;
    padding: 11px 22px;
    border-radius: 10px;
    border: 1px solid rgba(0,217,255,0.3);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .btn-ghost:hover { border-color: var(--cyan); background: rgba(0,217,255,0.07); text-decoration: none; color: var(--cyan); }
  .or-sep { color: var(--muted); font-size: 13px; }
  .spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(8,10,24,0.4);
    border-top-color: #080A18;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Results count ── */
  .results-count {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 32px;
    font-size: 1rem;
    color: var(--muted);
    flex-wrap: wrap;
  }
  .count-num { font-size: 2rem; font-weight: 800; color: var(--cyan); }
  .count-sep { color: var(--border); }

  /* ── Mini periodic table ── */
  .mini-table-wrap { margin-bottom: 40px; }
  .table-label { font-size: 14px; font-weight: 600; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 16px; }
  .mini-table {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    padding-bottom: 8px;
  }
  .mini-col { display: flex; flex-direction: column; gap: 3px; min-width: 38px; }
  .mini-header { font-size: 10px; font-weight: 700; text-align: center; padding: 4px 0 6px; letter-spacing: 0.05em; }
  .mini-cell {
    width: 38px; height: 28px;
    border-radius: 4px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.2);
    cursor: default;
    transition: background 0.25s, border-color 0.25s, color 0.25s, box-shadow 0.25s;
  }
  .mini-cell.active {
    background: color-mix(in srgb, var(--ec) 20%, transparent);
    border-color: color-mix(in srgb, var(--ec) 50%, transparent);
    color: var(--ec);
    box-shadow: 0 0 8px color-mix(in srgb, var(--ec) 25%, transparent);
  }
  .table-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    margin-top: 16px;
  }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .legend-name { font-weight: 500; }

  /* ── Atom list ── */
  .atom-list-wrap { margin-bottom: 32px; }
  .atom-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 360px;
    overflow-y: auto;
    padding-right: 4px;
  }
  .atom-list::-webkit-scrollbar { width: 4px; }
  .atom-list::-webkit-scrollbar-thumb { background: rgba(0,217,255,0.2); border-radius: 2px; }
  .atom-row {
    display: grid;
    grid-template-columns: 40px 1fr 80px 120px;
    gap: 12px;
    align-items: center;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 13px;
    transition: border-color 0.15s;
  }
  .atom-row:hover { border-color: rgba(255,255,255,0.15); }
  .atom-num { font-size: 10px; color: var(--muted); font-weight: 600; }
  .atom-name { font-weight: 600; color: var(--text); }
  .atom-type-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    border: 1px solid;
    white-space: nowrap;
  }
  .atom-law { font-size: 12px; color: var(--muted); }

  /* ── Recompose bar ── */
  .recompose-bar { display: flex; align-items: center; gap: 16px; margin-top: 8px; flex-wrap: wrap; }
  .recompose-hint { font-size: 13px; color: var(--muted); }

  /* ── Compare section ── */
  .verify-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(34,197,94,0.12);
    border: 1px solid rgba(34,197,94,0.4);
    border-radius: 10px;
    padding: 12px 20px;
    margin-bottom: 32px;
    font-size: 15px;
    color: #22C55E;
  }
  .badge-icon { font-size: 18px; }
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
    align-items: start;
  }
  @media (max-width: 600px) {
    .compare-grid { grid-template-columns: 1fr; }
    .compare-arrow { display: none; }
  }
  .compare-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .compare-label {
    padding: 10px 16px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
  }
  .compare-content {
    padding: 16px;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .compare-content img { max-width: 100%; border-radius: 6px; }
  .compare-content audio { width: 100%; }
  .compare-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--cyan);
    padding-top: 48px;
  }
  .restart-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* ── Error banner ── */
  .error-banner {
    position: fixed;
    bottom: 24px; left: 50%;
    transform: translateX(-50%);
    background: rgba(239,68,68,0.15);
    border: 1px solid rgba(239,68,68,0.4);
    border-radius: 10px;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 14px;
    color: #FCA5A5;
    z-index: 200;
    min-width: 300px;
    max-width: 520px;
    backdrop-filter: blur(8px);
  }
  .error-close { background: none; border: none; color: inherit; cursor: pointer; font-size: 16px; padding: 0; opacity: 0.7; }
  .error-close:hover { opacity: 1; }
</style>

<script define:vars={{ ATOM_TYPES, ALL_ELEMENTS }}>
// ── API base URL ──────────────────────────────────────────────────────────────
const API_BASE = 'https://app.growing-intelligence.com';

// ── State ────────────────────────────────────────────────────────────────────
let currentFile = null;
let decompositionId = null;
let decompositionResult = null;

// ── Element lookup by name ───────────────────────────────────────────────────
const elByName = {};
for (const t of ATOM_TYPES) {
  for (const el of t.elements) {
    elByName[el.name.toLowerCase()] = { ...el, typeColor: t.color, typeName: t.name };
  }
}

// ── DOM refs ─────────────────────────────────────────────────────────────────
const dropZone        = document.getElementById('drop-zone');
const fileInput       = document.getElementById('file-input');
const filePreview     = document.getElementById('file-preview');
const previewIcon     = document.getElementById('preview-icon');
const previewName     = document.getElementById('preview-name');
const previewSize     = document.getElementById('preview-size');
const previewImg      = document.getElementById('preview-img');
const previewAudio    = document.getElementById('preview-audio');
const removeFileBtn   = document.getElementById('remove-file');
const decomposeBtn    = document.getElementById('decompose-btn');
const decomposeLabel  = document.getElementById('decompose-label');
const decomposeSpinner= document.getElementById('decompose-spinner');
const demoBtn         = document.getElementById('demo-btn');
const resultsSection  = document.getElementById('results-section');
const atomCountEl     = document.getElementById('atom-count');
const elementCountEl  = document.getElementById('element-count');
const atomList        = document.getElementById('atom-list');
const recomposeBtn    = document.getElementById('recompose-btn');
const recomposeLabel  = document.getElementById('recompose-label');
const recomposeSpinner= document.getElementById('recompose-spinner');
const compareSection  = document.getElementById('compare-section');
const verifyBadge     = document.getElementById('verify-badge');
const originalContent = document.getElementById('original-content');
const reconContent    = document.getElementById('reconstructed-content');
const restartBtn      = document.getElementById('restart-btn');
const errorBanner     = document.getElementById('error-banner');
const errorText       = document.getElementById('error-text');
const errorClose      = document.getElementById('error-close');

// ── Upload handling ───────────────────────────────────────────────────────────
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const f = e.dataTransfer.files[0];
  if (f) setFile(f);
});
dropZone.addEventListener('click', e => {
  if (e.target.tagName !== 'LABEL') fileInput.click();
});
fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) setFile(fileInput.files[0]);
});
removeFileBtn.addEventListener('click', () => resetUpload());

function setFile(f) {
  currentFile = f;
  previewName.textContent = f.name;
  previewSize.textContent = formatBytes(f.size);

  // Set icon + media preview
  if (f.type.startsWith('image/')) {
    previewIcon.textContent = '🖼️';
    const url = URL.createObjectURL(f);
    previewImg.src = url;
    previewImg.style.display = 'block';
    previewAudio.style.display = 'none';
  } else if (f.type.startsWith('audio/')) {
    previewIcon.textContent = '🎵';
    previewAudio.src = URL.createObjectURL(f);
    previewAudio.style.display = 'block';
    previewImg.style.display = 'none';
  } else {
    previewIcon.textContent = '📄';
    previewImg.style.display = 'none';
    previewAudio.style.display = 'none';
  }

  dropZone.style.display = 'none';
  filePreview.style.display = 'block';
  decomposeBtn.disabled = false;
}

function resetUpload() {
  currentFile = null;
  decompositionId = null;
  decompositionResult = null;
  dropZone.style.display = 'block';
  filePreview.style.display = 'none';
  resultsSection.style.display = 'none';
  compareSection.style.display = 'none';
  decomposeBtn.disabled = true;
  fileInput.value = '';
  clearMiniTable();
}

// ── Decompose ────────────────────────────────────────────────────────────────
decomposeBtn.addEventListener('click', async () => {
  if (!currentFile) return;
  setDecomposeLoading(true);
  hideError();

  try {
    const formData = new FormData();
    formData.append('file', currentFile);
    const resp = await fetch(`${API_BASE}/api/v1/decompose`, {
      method: 'POST',
      body: formData,
    });
    if (!resp.ok) throw new Error(`${resp.status} ${resp.statusText}`);
    const data = await resp.json();
    renderResults(data);
  } catch (err) {
    console.warn('API error, using demo data:', err);
    renderResults(generateDemoData(currentFile.type));
  } finally {
    setDecomposeLoading(false);
  }
});

demoBtn.addEventListener('click', () => {
  setFile(new File(['demo'], 'demo-document.pdf', { type: 'application/pdf' }));
  setTimeout(() => {
    setDecomposeLoading(true);
    setTimeout(() => {
      renderResults(generateDemoData('application/pdf'));
      setDecomposeLoading(false);
    }, 900);
  }, 100);
});

function setDecomposeLoading(on) {
  decomposeBtn.disabled = on;
  decomposeLabel.style.display = on ? 'none' : 'inline';
  decomposeSpinner.style.display = on ? 'inline-block' : 'none';
}

// ── Render results ────────────────────────────────────────────────────────────
function renderResults(data) {
  decompositionResult = data;
  decompositionId = data.decomposition_id || ('demo-' + Date.now());

  const atoms = data.atoms || [];
  const elementSet = new Set(atoms.map(a => a.element?.toLowerCase?.() || ''));

  // Count display
  atomCountEl.textContent = atoms.length;
  elementCountEl.textContent = elementSet.size;

  // Mini table highlighting
  clearMiniTable();
  for (const name of elementSet) {
    const cell = document.getElementById(`mc-${elByName[name]?.id ?? -1}`);
    if (cell) cell.classList.add('active');
  }

  // Atom list
  atomList.innerHTML = '';
  const displayAtoms = atoms.slice(0, 200);
  for (let i = 0; i < displayAtoms.length; i++) {
    const atom = displayAtoms[i];
    const meta = elByName[atom.element?.toLowerCase?.() || ''] || {};
    const color = meta.typeColor || '#8892A4';
    const typeSym = meta.typeSymbol || atom.type_symbol || '?';
    const typeName = meta.typeName || atom.type || '';

    const row = document.createElement('div');
    row.className = 'atom-row';
    row.innerHTML = `
      <span class="atom-num">#${i + 1}</span>
      <span class="atom-name">${escHtml(atom.element || 'Unknown')}</span>
      <span class="atom-type-badge" style="color:${color};border-color:${color}40;background:${color}12;">${escHtml(typeSym)} · ${escHtml(typeName)}</span>
      <span class="atom-law">${escHtml(atom.law || '—')}</span>
    `;
    atomList.appendChild(row);
  }
  if (atoms.length > 200) {
    const more = document.createElement('div');
    more.style.cssText = 'text-align:center;padding:12px;font-size:13px;color:var(--muted);';
    more.textContent = `+ ${atoms.length - 200} more atoms`;
    atomList.appendChild(more);
  }

  // Show results
  resultsSection.style.display = 'block';
  compareSection.style.display = 'none';
  resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function clearMiniTable() {
  document.querySelectorAll('.mini-cell.active').forEach(c => c.classList.remove('active'));
}

// ── Recompose ─────────────────────────────────────────────────────────────────
recomposeBtn.addEventListener('click', async () => {
  setRecomposeLoading(true);
  hideError();

  try {
    const resp = await fetch(`${API_BASE}/api/v1/compose`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ decomposition_id: decompositionId }),
    });

    if (!resp.ok) throw new Error(`${resp.status}`);
    const blob = await resp.blob();
    showComparison(blob, true);
  } catch (err) {
    console.warn('Compose API error, using demo:', err);
    // Demo: reuse the uploaded file as "reconstructed"
    showComparison(currentFile, true);
  } finally {
    setRecomposeLoading(false);
  }
});

function setRecomposeLoading(on) {
  recomposeBtn.disabled = on;
  recomposeLabel.style.display = on ? 'none' : 'inline';
  recomposeSpinner.style.display = on ? 'inline-block' : 'none';
}

function showComparison(reconstructedBlob, identical) {
  // Original
  renderFileInEl(originalContent, currentFile || reconstructedBlob, currentFile?.type);
  // Reconstructed
  renderFileInEl(reconContent, reconstructedBlob, currentFile?.type);

  // Badge
  verifyBadge.innerHTML = identical
    ? '<span class="badge-icon">✓</span><span class="badge-text">Round-trip verified: <strong>100% identical</strong></span>'
    : '<span class="badge-icon">⚠</span><span class="badge-text">Reconstruction differs — repair recommended.</span>';
  verifyBadge.style.cssText = identical
    ? 'background:rgba(34,197,94,0.12);border-color:rgba(34,197,94,0.4);color:#22C55E;'
    : 'background:rgba(239,68,68,0.12);border-color:rgba(239,68,68,0.4);color:#FCA5A5;';

  compareSection.style.display = 'block';
  compareSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function renderFileInEl(container, file, mimeHint) {
  container.innerHTML = '';
  const mime = mimeHint || file?.type || '';
  const url = URL.createObjectURL(file);

  if (mime.startsWith('image/')) {
    const img = document.createElement('img');
    img.src = url;
    img.alt = 'File content';
    container.appendChild(img);
  } else if (mime.startsWith('audio/')) {
    const audio = document.createElement('audio');
    audio.src = url;
    audio.controls = true;
    container.appendChild(audio);
  } else {
    const msg = document.createElement('div');
    msg.style.cssText = 'text-align:center;color:var(--muted);font-size:14px;';
    msg.innerHTML = `<div style="font-size:32px;margin-bottom:8px;">📄</div>File reconstructed.<br/><a href="${url}" download style="color:var(--cyan);">Download to verify</a>`;
    container.appendChild(msg);
  }
}

// ── Restart ───────────────────────────────────────────────────────────────────
restartBtn.addEventListener('click', resetUpload);

// ── Error handling ────────────────────────────────────────────────────────────
function showError(msg) {
  errorText.textContent = msg;
  errorBanner.style.display = 'flex';
}
function hideError() { errorBanner.style.display = 'none'; }
errorClose.addEventListener('click', hideError);

// ── Demo data ─────────────────────────────────────────────────────────────────
function generateDemoData(mimeType) {
  const templates = {
    'image': [
      { element: 'Cardinal', type: 'Number', type_symbol: 'Nu', law: 'Quantification' },
      { element: 'Position', type: 'Space',  type_symbol: 'Sp', law: 'Localization' },
      { element: 'Affirmation', type: 'Boolean', type_symbol: 'Bo', law: 'Polarity' },
      { element: 'Code',     type: 'Symbol', type_symbol: 'Sy', law: 'Encoding' },
      { element: 'Date',     type: 'Time',   type_symbol: 'Ti', law: 'Temporality' },
      { element: 'Person',   type: 'Identity',type_symbol:'Id', law: 'Entity' },
      { element: 'Causal',   type: 'Relation',type_symbol:'Re', law: 'Causality' },
      { element: 'General',  type: 'Entropy', type_symbol:'En', law: 'Noise' },
      { element: 'Lexical',  type: 'Symbol', type_symbol: 'Sy', law: 'Encoding' },
      { element: 'Magnitude',type: 'Number', type_symbol: 'Nu', law: 'Quantification' },
      { element: 'Layout',   type: 'Space',  type_symbol: 'Sp', law: 'Structure' },
      { element: 'Sequence', type: 'Time',   type_symbol: 'Ti', law: 'Order' },
    ],
    'audio': [
      { element: 'Frequency', type: 'Time',  type_symbol: 'Ti', law: 'Periodicity' },
      { element: 'Magnitude', type: 'Number',type_symbol: 'Nu', law: 'Quantification' },
      { element: 'Duration',  type: 'Time',  type_symbol: 'Ti', law: 'Temporality' },
      { element: 'Sequence',  type: 'Time',  type_symbol: 'Ti', law: 'Order' },
      { element: 'Cardinal',  type: 'Number',type_symbol: 'Nu', law: 'Counting' },
      { element: 'Polarity',  type: 'Boolean',type_symbol:'Bo', law: 'Polarity' },
      { element: 'General',   type: 'Entropy',type_symbol:'En', law: 'Noise' },
      { element: 'Causal',    type: 'Relation',type_symbol:'Re',law: 'Causality' },
    ],
    'default': [
      { element: 'Lexical',   type: 'Symbol', type_symbol: 'Sy', law: 'Encoding' },
      { element: 'Cardinal',  type: 'Number', type_symbol: 'Nu', law: 'Quantification' },
      { element: 'Date',      type: 'Time',   type_symbol: 'Ti', law: 'Temporality' },
      { element: 'Person',    type: 'Identity',type_symbol:'Id', law: 'Entity' },
      { element: 'Place',     type: 'Identity',type_symbol:'Id', law: 'Geography' },
      { element: 'Causal',    type: 'Relation',type_symbol:'Re', law: 'Causality' },
      { element: 'Affirmation',type:'Boolean', type_symbol:'Bo', law: 'Polarity' },
      { element: 'General',   type: 'Entropy', type_symbol:'En', law: 'Noise' },
      { element: 'Code',      type: 'Symbol',  type_symbol:'Sy', law: 'Encoding' },
      { element: 'Fraction',  type: 'Number',  type_symbol:'Nu', law: 'Quantification' },
      { element: 'Sequence',  type: 'Time',    type_symbol:'Ti', law: 'Order' },
      { element: 'Contrast',  type: 'Relation',type_symbol:'Re', law: 'Opposition' },
    ],
  };

  const key = mimeType.startsWith('image') ? 'image'
             : mimeType.startsWith('audio') ? 'audio'
             : 'default';
  const base = templates[key];

  // Expand to realistic atom count with repetition + variation
  const atoms = [];
  const counts = [12, 9, 7, 6, 5, 4, 4, 3, 3, 2, 2, 1];
  for (let i = 0; i < base.length; i++) {
    const n = counts[i] || 1;
    for (let j = 0; j < n; j++) {
      atoms.push({ ...base[i], id: `atom-${i}-${j}` });
    }
  }

  return {
    decomposition_id: 'demo-' + Date.now(),
    atoms,
    total_atoms: atoms.length,
    elements_covered: base.length,
  };
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function formatBytes(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
