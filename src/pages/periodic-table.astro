---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ATOM_TYPES, ALL_ELEMENTS } from '../data/elements';
---

<BaseLayout
  title="Periodic Table of AI"
  description="56 universal neuron elements organized into 8 fundamental atom types. Every language model contains all of them. Explore the complete table."
>
  <script type="application/ld+json" slot="head">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "Holosynthics Periodic Table of AI — 56 Elements",
      "description": "56 universal neuron types across 11 language models",
      "creator": { "@type": "Organization", "name": "Holosynthics" },
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "url": "https://holosynthics.com/periodic-table"
    })}
  </script>

  <Nav />

  <main class="pt-page">
    <div class="pt-hero">
      <h1>The Periodic Table of <span class="accent">AI</span></h1>
      <p>56 universal neuron elements. 8 fundamental types. Every language model we tested contains all of them.</p>
      <div class="pt-legend">
        {ATOM_TYPES.map(t => (
          <button class="legend-item" data-type={t.symbol} style={`--tc: ${t.color};`}>
            <span class="ls" style={`color: ${t.color};`}>{t.symbol}</span>
            <span class="ln">{t.name}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Full interactive table -->
    <div class="full-table">
      <div class="table-grid" id="table-grid">
        {ATOM_TYPES.map((type) => (
          <div class="type-col" data-type={type.symbol}>
            <div class="col-header" style={`border-color: ${type.color}40; background: ${type.color}15;`}>
              <span class="cs" style={`color: ${type.color};`}>{type.symbol}</span>
              <span class="cn">{type.name}</span>
              <span class="cd">{type.description}</span>
            </div>
            {type.elements.map(el => (
              <div class="el-cell" id={`element-${el.id}`} style={`--ec: ${el.color};`}
                data-type={type.symbol}
                data-desc={el.description}
                tabindex="0"
                role="button"
                aria-label={`${el.name} — ${el.description}`}
              >
                <span class="en">{el.id}</span>
                <div class="ename">{el.name}</div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- Element detail panel (shown on click) -->
    <div class="detail-panel" id="detail-panel" hidden>
      <button class="close-detail" id="close-detail" aria-label="Close">&times;</button>
      <div id="detail-content"></div>
    </div>

    <!-- Element index — names and descriptions only -->
    <section class="index-section">
      <div class="index-container">
        <h2>All 56 Elements</h2>
        <p class="index-sub">Each element represents a distinct category of neuron function found universally across AI language models. Full quantitative data is available through GI X-Ray analysis.</p>
        <div class="index-grid">
          {ALL_ELEMENTS.map(el => (
            <div class="index-row" data-type={el.typeSymbol}>
              <span class="idx-num" style={`color: ${el.color};`}>{el.id}</span>
              <span class="idx-badge" style={`color: ${el.color}; border-color: ${el.color}40; background: ${el.color}10;`}>{el.typeSymbol}</span>
              <div class="idx-text">
                <span class="idx-name">{el.name}</span>
                <span class="idx-desc">{el.description}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pt-page { padding-top: 64px; }

  .pt-hero {
    text-align: center;
    padding: 80px 24px 60px;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(0,217,255,0.1) 0%, transparent 60%);
  }

  h1 {
    font-size: clamp(32px, 6vw, 60px);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #fff;
    margin-bottom: 16px;
  }

  .accent { color: var(--cyan); }

  .pt-hero p {
    font-size: 18px;
    color: var(--muted);
    max-width: 540px;
    margin: 0 auto 40px;
  }

  .pt-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--tc, #fff);
    background: color-mix(in srgb, var(--tc, #fff) 10%, transparent);
    padding: 6px 14px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    transition: background 0.2s;
  }

  .legend-item:hover, .legend-item.active {
    background: color-mix(in srgb, var(--tc, #fff) 20%, transparent);
  }

  .ls { font-weight: 800; font-size: 15px; }
  .ln { color: var(--muted); }

  .full-table {
    overflow-x: auto;
    padding: 40px 24px;
    background: var(--bg2);
  }

  .table-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(120px, 1fr));
    gap: 10px;
    min-width: 840px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .type-col { display: flex; flex-direction: column; gap: 6px; }

  .col-header {
    border: 1px solid;
    border-radius: 10px 10px 4px 4px;
    padding: 14px 10px;
    text-align: center;
    margin-bottom: 4px;
  }

  .cs { display: block; font-size: 24px; font-weight: 800; line-height: 1; }
  .cn { display: block; font-size: 11px; font-weight: 700; color: #E2E8F0; margin-top: 4px; }
  .cd { display: block; font-size: 9px; color: var(--muted); margin-top: 4px; line-height: 1.4; }

  .el-cell {
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 10px 8px;
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    transition: 0.2s;
    position: relative;
    overflow: hidden;
    outline: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .el-cell::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--ec);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .el-cell:hover, .el-cell:focus {
    border-color: var(--ec);
    background: rgba(255,255,255,0.05);
    transform: translateY(-2px);
  }

  .el-cell:hover::after, .el-cell:focus::after { opacity: 1; }

  .en { font-size: 9px; color: var(--muted); line-height: 1; }
  .ename { font-size: 12px; font-weight: 700; color: #E2E8F0; line-height: 1.3; }

  /* Detail panel */
  .detail-panel {
    position: fixed;
    right: 0; top: 0; bottom: 0;
    width: min(420px, 92vw);
    background: #0F1225;
    border-left: 1px solid rgba(0,217,255,0.2);
    z-index: 200;
    padding: 36px 32px;
    overflow-y: auto;
    animation: slideIn 0.25s ease;
  }

  @keyframes slideIn {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }

  .close-detail {
    position: absolute;
    top: 16px; right: 16px;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 24px;
    cursor: pointer;
    line-height: 1;
  }

  .close-detail:hover { color: #fff; }

  /* Element index */
  .index-section { padding: 80px 24px; }
  .index-container { max-width: 960px; margin: 0 auto; }

  .index-section h2 {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .index-sub {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 36px;
    line-height: 1.7;
    max-width: 640px;
  }

  .index-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .index-row {
    display: grid;
    grid-template-columns: 28px 36px 1fr;
    align-items: baseline;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }

  .index-row:last-child { border-bottom: none; }

  .idx-num {
    font-size: 11px;
    font-weight: 700;
    text-align: right;
  }

  .idx-badge {
    font-size: 10px;
    font-weight: 700;
    border: 1px solid;
    padding: 2px 5px;
    border-radius: 4px;
    text-align: center;
    white-space: nowrap;
  }

  .idx-text {
    display: flex;
    gap: 10px;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .idx-name {
    font-size: 14px;
    font-weight: 600;
    color: #E2E8F0;
    white-space: nowrap;
  }

  .idx-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .index-row { grid-template-columns: 24px 32px 1fr; gap: 8px; }
    .idx-desc { display: block; width: 100%; }
    .idx-text { flex-direction: column; gap: 2px; }
  }
</style>

<script>
  // Filter by type
  document.querySelectorAll('.legend-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.type;
      const isActive = btn.classList.contains('active');
      document.querySelectorAll('.legend-item').forEach(b => b.classList.remove('active'));

      if (!isActive) {
        btn.classList.add('active');
        document.querySelectorAll('.el-cell').forEach(cell => {
          cell.style.opacity = cell.dataset.type === type ? '1' : '0.15';
        });
        document.querySelectorAll('.index-row').forEach(row => {
          row.style.opacity = row.dataset.type === type ? '1' : '0.15';
        });
      } else {
        document.querySelectorAll('.el-cell, .index-row').forEach(el => {
          el.style.opacity = '';
        });
      }
    });
  });

  // Element click detail panel
  const panel = document.getElementById('detail-panel');
  const content = document.getElementById('detail-content');
  const closeBtn = document.getElementById('close-detail');

  document.querySelectorAll('.el-cell').forEach(cell => {
    cell.addEventListener('click', () => {
      const name = cell.querySelector('.ename').textContent;
      const type = cell.dataset.type;
      const desc = cell.dataset.desc;
      const color = getComputedStyle(cell).getPropertyValue('--ec').trim();

      content.innerHTML = `
        <div style="color:${color};font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px">${type}</div>
        <h2 style="font-size:30px;font-weight:800;color:#fff;margin-bottom:20px;line-height:1.15">${name}</h2>
        <p style="font-size:15px;color:#94A3B8;line-height:1.8;margin-bottom:28px">${desc}</p>
        <div style="border:1px solid rgba(0,217,255,0.15);border-radius:12px;padding:20px;background:rgba(0,217,255,0.04);margin-bottom:24px;">
          <div style="font-size:12px;color:#8892A4;font-weight:600;letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;">Quantitative Data</div>
          <div style="font-size:13px;color:#94A3B8;line-height:1.7">
            Neuron counts, layer distributions, and mean magnitude scores for each element
            are available through GI X-Ray analysis. <a href="/darkfield" style="color:var(--cyan)">Request a scan &rarr;</a>
          </div>
        </div>
        <a href="/research" style="display:inline-block;color:var(--cyan);font-size:14px;font-weight:600;text-decoration:none;border-bottom:1px solid rgba(0,217,255,0.4);padding-bottom:2px;">
          Read the Research Papers &rarr;
        </a>
      `;
      panel.hidden = false;
    });
  });

  closeBtn?.addEventListener('click', () => { panel.hidden = true; });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') panel.hidden = true; });
</script>
