---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ATOM_TYPES, ALL_ELEMENTS } from '../data/elements';
---

<BaseLayout
  title="Periodic Table of AI"
  description="56 universal neuron elements organized into 8 fundamental atom types. Every language model contains all of them. Explore the complete table."
>
  <script type="application/ld+json" slot="head">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "Holosynthics Periodic Table of AI — 56 Elements",
      "description": "56 universal neuron types across 11 language models",
      "creator": { "@type": "Organization", "name": "Holosynthics" },
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "url": "https://holosynthics.com/periodic-table"
    })}
  </script>

  <Nav />

  <main class="pt-page">
    <div class="pt-hero">
      <h1>The Periodic Table of <span class="accent">AI</span></h1>
      <p>56 universal neuron elements. 8 fundamental types. Every language model we tested contains all of them.</p>
      <div class="pt-legend">
        {ATOM_TYPES.map(t => (
          <a href={`/periodic-table/${t.name.toLowerCase()}`} class="legend-item" style={`--tc: ${t.color};`}>
            <span class="ls" style={`color: ${t.color};`}>{t.symbol}</span>
            <span class="ln">{t.name}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Full interactive table -->
    <div class="full-table">
      <div class="table-grid" id="table-grid">
        {ATOM_TYPES.map((type) => (
          <div class="type-col" data-type={type.symbol}>
            <a href={`/periodic-table/${type.name.toLowerCase()}`} class="col-header" style={`border-color: ${type.color}40; background: ${type.color}15;`}>
              <span class="cs" style={`color: ${type.color};`}>{type.symbol}</span>
              <span class="cn">{type.name}</span>
              <span class="cd">{type.description}</span>
            </a>
            {type.elements.map(el => (
              <a
                href={`/periodic-table/${type.name.toLowerCase()}/${el.name.toLowerCase()}`}
                class="el-cell"
                id={`element-${el.id}`}
                style={`--ec: ${el.color};`}
                data-type={type.symbol}
                aria-label={`${el.name} — ${el.description}`}
              >
                <span class="en">{el.id}</span>
                <div class="ename">{el.name}</div>
                <div class="edesc">{el.description}</div>
              </a>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- Element index — names and descriptions only -->
    <section class="index-section">
      <div class="index-container">
        <h2>All 56 Elements</h2>
        <p class="index-sub">Each element represents a distinct category of neuron function found universally across AI language models. Click any element to read its full description.</p>
        <div class="index-grid">
          {ALL_ELEMENTS.map(el => {
            const typeSlug = ATOM_TYPES.find(t => t.symbol === el.typeSymbol)?.name.toLowerCase() ?? '';
            return (
              <a href={`/periodic-table/${typeSlug}/${el.name.toLowerCase()}`} class="index-row" data-type={el.typeSymbol}>
                <span class="idx-num" style={`color: ${el.color};`}>{el.id}</span>
                <span class="idx-badge" style={`color: ${el.color}; border-color: ${el.color}40; background: ${el.color}10;`}>{el.typeSymbol}</span>
                <div class="idx-text">
                  <span class="idx-name">{el.name}</span>
                  <span class="idx-desc">{el.description}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pt-page { padding-top: 64px; }

  .pt-hero {
    text-align: center;
    padding: 80px 24px 60px;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(0,217,255,0.1) 0%, transparent 60%);
  }

  h1 {
    font-size: clamp(32px, 6vw, 60px);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #fff;
    margin-bottom: 16px;
  }

  .accent { color: var(--cyan); }

  .pt-hero p {
    font-size: 18px;
    color: var(--muted);
    max-width: 540px;
    margin: 0 auto 40px;
  }

  .pt-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--tc, #fff);
    background: color-mix(in srgb, var(--tc, #fff) 10%, transparent);
    padding: 6px 14px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    transition: background 0.2s;
    text-decoration: none;
  }

  .legend-item:hover {
    background: color-mix(in srgb, var(--tc, #fff) 20%, transparent);
    text-decoration: none;
  }

  .ls { font-weight: 800; font-size: 15px; }
  .ln { color: var(--muted); }

  .full-table {
    overflow-x: auto;
    padding: 40px 24px;
    background: var(--bg2);
  }

  .table-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(120px, 1fr));
    gap: 10px;
    min-width: 840px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .type-col { display: flex; flex-direction: column; gap: 6px; }

  .col-header {
    border: 1px solid;
    border-radius: 10px 10px 4px 4px;
    padding: 14px 10px;
    text-align: center;
    margin-bottom: 4px;
    text-decoration: none;
    display: block;
    transition: opacity 0.2s;
  }

  .col-header:hover { opacity: 0.85; text-decoration: none; }

  .cs { display: block; font-size: 24px; font-weight: 800; line-height: 1; }
  .cn { display: block; font-size: 11px; font-weight: 700; color: #E2E8F0; margin-top: 4px; }
  .cd { display: block; font-size: 9px; color: var(--muted); margin-top: 4px; line-height: 1.4; }

  .el-cell {
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    padding: 10px 8px;
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    transition: 0.2s;
    position: relative;
    overflow: hidden;
    outline: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
  }

  .el-cell::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--ec);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .el-cell:hover, .el-cell:focus {
    border-color: var(--ec);
    background: rgba(255,255,255,0.05);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .el-cell:hover::after, .el-cell:focus::after { opacity: 1; }

  .en { font-size: 9px; color: var(--muted); line-height: 1; }
  .ename { font-size: 12px; font-weight: 700; color: #E2E8F0; line-height: 1.3; }
  .edesc { font-size: 9px; color: var(--muted); line-height: 1.4; display: none; }

  /* Element index */
  .index-section { padding: 80px 24px; }
  .index-container { max-width: 960px; margin: 0 auto; }

  .index-section h2 {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .index-sub {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 36px;
    line-height: 1.7;
    max-width: 640px;
  }

  .index-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .index-row {
    display: grid;
    grid-template-columns: 28px 36px 1fr;
    align-items: baseline;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s;
    border-radius: 4px;
    padding-inline: 4px;
  }

  .index-row:last-child { border-bottom: none; }

  .index-row:hover {
    background: rgba(255,255,255,0.03);
    text-decoration: none;
  }

  .idx-num {
    font-size: 11px;
    font-weight: 700;
    text-align: right;
  }

  .idx-badge {
    font-size: 10px;
    font-weight: 700;
    border: 1px solid;
    padding: 2px 5px;
    border-radius: 4px;
    text-align: center;
    white-space: nowrap;
  }

  .idx-text {
    display: flex;
    gap: 10px;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .idx-name {
    font-size: 14px;
    font-weight: 600;
    color: #E2E8F0;
    white-space: nowrap;
  }

  .idx-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .index-row { grid-template-columns: 24px 32px 1fr; gap: 8px; }
    .idx-desc { display: block; width: 100%; }
    .idx-text { flex-direction: column; gap: 2px; }
  }
</style>
