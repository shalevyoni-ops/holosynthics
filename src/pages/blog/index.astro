---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Blog"
  description="Holosynthics research blog — AI interpretability, hallucination experiments, neuron analysis, and the periodic table of AI."
>
  <Nav />

  <main class="blog-index">
    <div class="blog-hero">
      <h1>Blog</h1>
      <p>Research findings, experiments, and thoughts on AI interpretability.</p>
    </div>

    <div class="posts-container">
      <div class="posts-grid">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-date">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="read-more">Read article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-index { padding-top: 64px; }

  .blog-hero {
    text-align: center;
    padding: 80px 24px 60px;
    background: radial-gradient(ellipse 50% 40% at 50% 0%, rgba(0,217,255,0.08) 0%, transparent 60%);
  }

  h1 {
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #fff;
    margin-bottom: 16px;
  }

  .blog-hero p { font-size: 18px; color: var(--muted); }

  .posts-container { max-width: 760px; margin: 0 auto; padding: 40px 24px 80px; }

  .posts-grid { display: flex; flex-direction: column; gap: 24px; }

  .post-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    background: var(--bg2);
    text-decoration: none;
    transition: border-color 0.3s, transform 0.2s;
  }

  .post-card:hover {
    border-color: rgba(0,217,255,0.3);
    transform: translateY(-3px);
    text-decoration: none;
  }

  .post-date {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .post-card h2 {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .post-card p {
    font-size: 15px;
    color: #94A3B8;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .read-more {
    font-size: 14px;
    font-weight: 600;
    color: var(--cyan);
  }
</style>
