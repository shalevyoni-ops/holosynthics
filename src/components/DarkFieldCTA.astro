---
import Particles from './Particles.astro';
---

<section class="cta-section">
  <div class="cta-bg" role="presentation">
    <img
      src="/img/fractal_0.png"
      alt=""
      class="cta-img"
      loading="lazy"
      decoding="async"
    />
    <div class="cta-overlay"></div>
  </div>
  <Particles id="cta-canvas" count={50} />

  <div class="cta-inner">
    <div class="cta-badge">Open Source · MIT License</div>
    <h2>Start Scanning Your Model Today</h2>
    <p>DarkField extracts neuron activations from any HuggingFace model. Free, open-source, and runs locally.</p>

    <div class="install-box">
      <code>pip install darkfield</code>
      <button class="copy-btn" id="copy-pip" aria-label="Copy install command">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
      </button>
    </div>

    <div class="cta-steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-text">
          <strong>Install</strong>
          <span>pip install darkfield</span>
        </div>
      </div>
      <div class="step-arrow">&rarr;</div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-text">
          <strong>Scan</strong>
          <span>darkfield scan --model gpt2</span>
        </div>
      </div>
      <div class="step-arrow">&rarr;</div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-text">
          <strong>Analyze</strong>
          <span>Send bundle to GI X-Ray</span>
        </div>
      </div>
    </div>

    <div class="cta-actions">
      <a href="https://github.com/growing-intelligence/darkfield" target="_blank" rel="noopener" class="btn-github">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
      <a href="/darkfield" class="btn-scan">Get Full X-Ray Scan</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: 100px 24px;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .cta-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.55;
    filter: saturate(1.4) brightness(0.65) hue-rotate(-10deg);
  }

  .cta-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,217,255,0.06) 0%, transparent 60%),
      rgba(8,10,24,0.6);
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-badge {
    display: inline-block;
    border: 1px solid rgba(0,217,255,0.3);
    color: var(--cyan);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 24px;
    background: rgba(0,217,255,0.06);
  }

  h2 {
    font-size: clamp(24px, 4vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 16px;
  }

  p {
    font-size: 18px;
    color: var(--muted);
    margin-bottom: 36px;
  }

  .install-box {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(0,217,255,0.25);
    border-radius: 10px;
    padding: 14px 20px;
    margin-bottom: 48px;
  }

  .install-box code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 16px;
    color: var(--cyan);
    background: none;
    padding: 0;
  }

  .copy-btn {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .copy-btn:hover { color: var(--cyan); }

  .cta-steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .step {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0,217,255,0.12);
    border: 1px solid rgba(0,217,255,0.3);
    color: var(--cyan);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .step-text strong {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .step-text span {
    font-size: 11px;
    color: var(--muted);
    font-family: monospace;
  }

  .step-arrow {
    color: var(--muted);
    font-size: 20px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-github {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 600;
    font-size: 15px;
    padding: 13px 28px;
    border-radius: 10px;
    text-decoration: none;
    background: rgba(255,255,255,0.05);
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-github:hover { border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); text-decoration: none; }

  .btn-scan {
    background: linear-gradient(135deg, var(--cyan), #0099BB);
    color: #080A18;
    font-weight: 700;
    font-size: 15px;
    padding: 13px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-scan:hover { opacity: 0.85; text-decoration: none; }

  @media (max-width: 600px) {
    .step-arrow { display: none; }
    .cta-steps { gap: 12px; }
  }
</style>

<script>
  document.getElementById('copy-pip')?.addEventListener('click', () => {
    navigator.clipboard?.writeText('pip install darkfield');
  });
</script>
